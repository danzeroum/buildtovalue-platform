# Config por ambiente (12-factor, G-COD-4). NUNCA commitar .env real.
# Validada em packages/config (zod) — app não sobe com config inválida.

NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=3000
API_HOST=0.0.0.0
# Rate limit por tenant (janela de 1 minuto)
RATE_LIMIT_MAX=120

# Banco — papel de APLICAÇÃO (app_api): SEM bypassrls (D7).
DATABASE_URL=postgres://app_api:app_api_dev@localhost:5432/buildtovalue
# Banco — papel de MIGRAÇÃO (separado do papel da API, D7/8.4).
DATABASE_MIGRATION_URL=postgres://app_migrator:app_migrator_dev@localhost:5432/buildtovalue

# Auth (JWT curto + refresh — F1.4). Segredo dev APENAS; produção via secret manager.
JWT_SECRET=dev-only-change-me-32-bytes-minimum!!
# KeyProvider dev/CI (D20) para campos sensitive — produção usa KMS (F5)
FIELD_KEY_SECRET=troque-este-segredo-dev
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Observabilidade
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=buildtovalue-api

# Testes de integração (papéis criados pela migração 0001)
# DATABASE_URL_TEST=postgres://app_migrator:app_migrator_dev@localhost:5432/buildtovalue_test

# ════════════════════════════════════════════════════════════════════════
# DEPLOY NA VPS (deploy/docker-compose.yml) — variáveis do .env que o compose lê.
# As acima (DATABASE_URL etc.) o compose injeta direto nos serviços; abaixo é o
# que VOCÊ preenche no .env da VPS. Ver docs/runbooks/deploy-vps.md.
# ════════════════════════════════════════════════════════════════════════

# ── OBRIGATÓRIO ──
# Senha do papel de MIGRAÇÃO (dono do banco no container). O app_api usa senha
# própria fixada pela migração (app_api_dev) — ok no teste, NÃO no piloto.
MIGRATOR_PASSWORD=troque-esta-senha-de-migracao
# JWT_SECRET e FIELD_KEY_SECRET: reuse os de cima (>=32 e >=16). Não deixe os defaults.

# ── OPCIONAL ──
# Porta do HOST onde a api fica presa em 127.0.0.1 (o ingress faz o proxy).
API_HOST_PORT=3000
# §A — resolvedor de secret:// (chave do AIProvider). backend `env` ou `file`:
#   env : defina SECRET_<PATH> (ex.: SECRET_TENANTS_ACME_AI_KEY=sk-ant-...)
#   file: SECRET_DIR aponta um dir com arquivos chmod 600 (fail-closed)
SECRET_BACKEND=env
SECRET_DIR=/run/secrets/btv
# Exemplo (backend env) p/ key_ref = secret://tenants/acme/ai-key no banco:
# SECRET_TENANTS_ACME_AI_KEY=sk-ant-...
