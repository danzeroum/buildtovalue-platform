# Config por ambiente (12-factor, G-COD-4). NUNCA commitar .env real.
# Validada em packages/config (zod) — app não sobe com config inválida.

NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=3000
API_HOST=0.0.0.0
# Rate limit por tenant (janela de 1 minuto)
RATE_LIMIT_MAX=120

# Banco — papel de APLICAÇÃO (app_api): SEM bypassrls (D7).
DATABASE_URL=postgres://app_api:app_api_dev@localhost:5432/buildtovalue
# Banco — papel de MIGRAÇÃO (separado do papel da API, D7/8.4).
DATABASE_MIGRATION_URL=postgres://app_migrator:app_migrator_dev@localhost:5432/buildtovalue

# Auth (JWT curto + refresh — F1.4). Segredo dev APENAS; produção via secret manager.
JWT_SECRET=dev-only-change-me-32-bytes-minimum!!
# KeyProvider dev/CI (D20) para campos sensitive — produção usa KMS (F5)
FIELD_KEY_SECRET=troque-este-segredo-dev
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Observabilidade
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=buildtovalue-api

# Testes de integração (papéis criados pela migração 0001)
# DATABASE_URL_TEST=postgres://app_migrator:app_migrator_dev@localhost:5432/buildtovalue_test
