{
  "name": "@platform/console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run sdk:generate && vite build",
    "typecheck": "pnpm run sdk:generate && tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "sdk:generate": "pnpm --filter @platform/api run build && pnpm --filter @platform/api openapi:emit ../console/openapi.json && openapi-typescript openapi.json -o src/api/generated/schema.d.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@platform/shared-ui": "workspace:*",
    "openapi-fetch": "^0.13.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "@buildtovalue/core": "1.2.0-next.0",
    "@buildtovalue/forms": "1.0.0-next.1",
    "@buildtovalue/forms-react": "1.0.0-next.1",
    "@buildtovalue/react": "1.2.0-next.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.7",
    "jsdom": "^25.0.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "vitest-axe": "^0.1.0"
  }
}
