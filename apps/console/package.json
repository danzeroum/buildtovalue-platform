{
  "name": "@platform/console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run sdk:generate && vite build",
    "typecheck": "pnpm run sdk:generate && tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "sdk:generate": "pnpm --filter @platform/api run build && pnpm --filter @platform/api openapi:emit ../console/openapi.json && openapi-typescript openapi.json -o src/api/generated/schema.d.ts"
  },
  "dependencies": {
    "@platform/shared-ui": "workspace:*",
    "openapi-fetch": "^0.13.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
