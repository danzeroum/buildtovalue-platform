{
  "name": "@platform/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/migrate-cli.ts"
  },
  "dependencies": {
    "postgres": "^3.4.7",
    "@buildtovalue/engine": "1.1.0-next.3",
    "@buildtovalue/core": "1.2.0-next.0",
    "@buildtovalue/agentflow": "1.1.0-next.1",
    "@buildtovalue/forms": "1.0.0-next.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
