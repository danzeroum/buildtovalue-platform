# API — multi-stage, runtime SEM devDependencies (pnpm deploy --prod).
# Contexto de build = raiz do repo (o compose passa context: ..).

FROM node:22-slim AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm -r build
# Empacota @platform/api + suas deps de workspace (dist) + deps de PROD, sem devDeps.
RUN pnpm --filter=@platform/api --prod deploy /prod/api

FROM node:22-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app
COPY --from=builder /prod/api ./
USER node
EXPOSE 3000
# server.ts lê a config de process.env (o compose injeta) — sem --env-file.
CMD ["node", "dist/server.js"]
