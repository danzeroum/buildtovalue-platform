# Migração ONE-SHOT — roda com o PAPEL DE MIGRAÇÃO (DATABASE_MIGRATION_URL) e
# sai. A api/worker só sobem depois (service_completed_successfully).
# O pacote @platform/db embarca `dist` + `migrations` (package.json "files").
# migrate-cli resolve `../migrations` a partir de dist/ — forward-only.

FROM node:22-slim AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm -r build
RUN pnpm --filter=@platform/db --prod deploy /prod/db

FROM node:22-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app
COPY --from=builder /prod/db ./
USER node
CMD ["node", "dist/migrate-cli.js"]
