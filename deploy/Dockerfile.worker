# Worker — multi-stage, runtime SEM devDependencies. Contexto = raiz do repo.

FROM node:22-slim AS builder
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm -r build
RUN pnpm --filter=@platform/worker --prod deploy /prod/worker

FROM node:22-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app
COPY --from=builder /prod/worker ./
USER node
# Sem porta publicada; /metrics interno. Conexão DIRETA ao Postgres.
CMD ["node", "dist/main.js"]
